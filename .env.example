# =============================================================================
# SFU Surge Finance Dashboard V2.2 — Vercel environment variables
# Copy to `.env.local` for local dev; set the same keys in the Vercel project
# settings for deployment. NEVER commit real values (.gitignore excludes .env*).
# =============================================================================

# --- REQUIRED ---------------------------------------------------------------

# The Apps Script Web App deployment URL (Deploy → "Execute as: Me",
# "Who has access: Anyone"). Treat as a secret — anyone with it can read
# dashboard data. Server-side only (never exposed to the browser). §1.3
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec

# Shared secret for the on-edit revalidation webhook (D1 / §6.1). MUST match the
# Apps Script Script Property `SURGE_REVALIDATE_SECRET` (auto-generated by
# getRevalidateSecret() on first run — read it from Project Settings → Script
# Properties and paste here). Used by POST /api/revalidate to authenticate
# Apps Script revalidation calls.
REVALIDATE_SECRET=paste-the-SURGE_REVALIDATE_SECRET-value-here

# --- OPTIONAL (public form links shown on /status) --------------------------
# The "Submit a Receipt" / "Submit Mileage" buttons on the public status page.
# Safe to be public. If omitted, the built-in defaults in src/lib/forms.ts are used.
NEXT_PUBLIC_RECEIPT_FORM_URL=https://forms.gle/Ms4xoWQFZZ3i22Fx5
NEXT_PUBLIC_MILEAGE_FORM_URL=https://forms.gle/VGFQYH5YXo1XVmUE7

# --- NOTES ------------------------------------------------------------------
# • No NEXT_PUBLIC_* variables are needed: ALL data is fetched server-side
#   through the Apps Script Web App. The dashboard token lives in an httpOnly
#   cookie, never in client JS.
# • The dashboard PASSWORD is configured in the Google Sheet (Settings →
#   "Dashboard Password", default `Spendy-Otter`), NOT here.
# • On the Apps Script side, set the Web App's Revalidate Webhook URL setting
#   (Settings sheet → "Revalidate Webhook URL") to:
#       https://<your-vercel-domain>/api/revalidate
#   so significant edits invalidate the ISR cache within seconds.
